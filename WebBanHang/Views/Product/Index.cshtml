@{
    ViewData["Title"] = "Sản phẩm";
}

<!-- Promotional Banner -->
<section class="promo-banner py-3" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="container-xxl">
        <div class="row align-items-center text-white g-2">
            <div class="col-md-8">
                <h2 class="fw-bold mb-1 fs-4">🔥 Ưu đãi đặc biệt hôm nay!</h2>
                <p class="mb-0 small">Giảm giá lên đến 12% cho sản phẩm chọn lọc - Số lượng có hạn</p>
            </div>
            <div class="col-md-4 text-md-end mt-2 mt-md-0">
                <a href="#deals" class="btn btn-light btn-sm px-4 shadow-sm">
                    <i class="fas fa-fire me-1"></i>Xem ngay
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Breadcrumb & Title -->
<section class="py-2 bg-light border-bottom">
    <div class="container-xxl">
        @await Html.PartialAsync("_Breadcrumb")
        <div class="row align-items-center mt-1">
            <div class="col-md-6">
                <h1 class="fw-bold mb-1 fs-3">Sản phẩm nổi bật</h1>
                <p class="text-muted mb-0 small">Khám phá các sản phẩm chất lượng cao</p>
            </div>
            <div class="col-md-6 text-md-end">
                <div class="d-flex gap-2 justify-content-md-end mt-2 mt-md-0 flex-wrap">
                    <span class="badge bg-danger px-2 py-1">
                        <i class="fas fa-tag me-1"></i>Sale
                    </span>
                    <span class="badge bg-primary px-2 py-1">
                        <i class="fas fa-star me-1"></i>Hot
                    </span>
                    <span class="badge bg-success px-2 py-1">
                        <i class="fas fa-sparkles me-1"></i>New
                    </span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Quick Category Filters -->
<section class="py-2 bg-white border-bottom">
    <div class="container-xxl">
        <div class="d-flex gap-2 overflow-auto pb-1 quick-filters">
            <button class="btn btn-sm btn-outline-primary rounded-pill px-3 py-1 active" data-filter="all">
                <i class="fas fa-th me-1"></i>Tất cả
            </button>
            <button class="btn btn-sm btn-outline-danger rounded-pill px-3 py-1" data-filter="sale">
                <i class="fas fa-percentage me-1"></i>Giảm giá
            </button>
            <button class="btn btn-sm btn-outline-primary rounded-pill px-3 py-1" data-filter="laptop">
                <i class="fas fa-laptop me-1"></i>Laptop
            </button>
            <button class="btn btn-sm btn-outline-info rounded-pill px-3 py-1" data-filter="phukien">
                <i class="fas fa-mouse me-1"></i>Phụ kiện
            </button>
            <button class="btn btn-sm btn-outline-success rounded-pill px-3 py-1" data-filter="new">
                <i class="fas fa-certificate me-1"></i>Mới nhất
            </button>
            <button class="btn btn-sm btn-outline-warning rounded-pill px-3 py-1" data-filter="lowstock">
                <i class="fas fa-exclamation-triangle me-1"></i>Sắp hết
            </button>
        </div>
    </div>
</section>

<!-- Products Section -->
<section class="py-3 bg-light">
    <div class="container-xxl">
        <!-- Toolbar với Sort, Page Size và Product Count -->
        <div class="row align-items-center mb-3 g-2">
            <div class="col-auto">
                <small class="text-muted me-1">Hiện có</small>
                <span id="productsCount" class="fw-bold text-primary">0 sản phẩm</span>
            </div>

            <div class="col-auto ms-auto">
                <!-- Sort Dropdown -->
                <select id="sortSelect" class="form-select form-select-sm shadow-sm" style="min-width: 160px;">
                    <option value="">Sắp xếp mặc định</option>
                    <option value="price_asc">Giá: Thấp → Cao</option>
                    <option value="price_desc">Giá: Cao → Thấp</option>
                    <option value="name_asc">Tên: A → Z</option>
                    <option value="name_desc">Tên: Z → A</option>
                    <option value="newest">Mới nhất</option>
                </select>
            </div>

            <div class="col-auto">
                <!-- Items Per Page -->
                <select id="pageSizeSelect" class="form-select form-select-sm shadow-sm" style="min-width: 100px;">
                    <option value="8" selected>8 / trang</option>
                    <option value="12">12 / trang</option>
                    <option value="16">16 / trang</option>
                    <option value="24">24 / trang</option>
                    <option value="0">Tất cả</option>
                </select>
            </div>
        </div>

        <!-- Products Grid - Tighter spacing -->
        <div id="productsContainer" class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-3 mb-3">
            <!-- Loading State -->
            <div class="col-12 text-center py-4 products-loading">
                <div class="spinner-border text-primary mb-2" style="width: 2.5rem; height: 2.5rem;" role="status">
                    <span class="visually-hidden">Đang tải...</span>
                </div>
                <p class="text-muted fw-semibold mb-0 small">Đang tải sản phẩm...</p>
            </div>
        </div>

        <!-- Pagination - Aligned to right -->
        <div class="d-flex justify-content-end mt-3 w-100">
            <div id="paginationContainer" class="ms-auto"></div>
        </div>
    </div>
</section>

<!-- Product Detail Modal -->
<div class="modal fade" id="productDetailModal" tabindex="-1" aria-labelledby="productDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title fw-bold" id="productDetailModalLabel">
                    <i class="fas fa-box-open me-2"></i>Chi tiết sản phẩm
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body p-3">
                <!-- Product Name -->
                <h4 id="modalProductName" class="fw-bold text-dark mb-3 text-center"></h4>

                <div class="row g-3">
                    <!-- Product Info - Left Side -->
                    <div class="col-md-7 order-md-1">
                        <!-- Description -->
                        <div class="mb-3">
                            <h6 class="fw-bold text-dark mb-2 pb-1 border-bottom border-primary">
                                <i class="fas fa-info-circle me-2 text-primary"></i>Mô tả sản phẩm
                            </h6>
                            <p id="modalProductDescription" class="text-muted mb-0 small" style="line-height: 1.6;"></p>
                        </div>

                        <!-- Long Description -->
                        <div id="modalLongDescriptionSection" class="mb-3">
                            <h6 class="fw-bold text-dark mb-2 pb-1 border-bottom border-primary">
                                <i class="fas fa-align-left me-2 text-primary"></i>Mô tả chi tiết
                            </h6>
                            <p id="modalProductLongDescription" class="text-muted mb-0 small" style="line-height: 1.6;"></p>
                        </div>

                        <!-- Specifications -->
                        <div id="modalSpecificationsSection" class="mb-2">
                            <h6 class="fw-bold text-dark mb-2 pb-1 border-bottom border-primary">
                                <i class="fas fa-list-ul me-2 text-primary"></i>Thông số kỹ thuật
                            </h6>
                            <div id="modalProductSpecifications" class="text-muted small"></div>
                        </div>
                    </div>

                    <!-- Product Image - Right Side -->
                    <div class="col-md-5 order-md-2">
                        <div class="position-relative">
                            <img id="modalProductImage" src="" alt="" class="img-fluid rounded shadow-sm w-100" style="max-height: 350px; object-fit: contain; background: #f8f9fa;">
                            <div id="modalProductBadges" class="position-absolute top-0 start-0 m-2"></div>
                        </div>

                        <!-- Price Section - Below Image -->
                        <div class="mt-3 p-2 bg-light rounded shadow-sm">
                            <div id="modalProductPrices" class="d-flex align-items-center gap-2 flex-wrap justify-content-center">
                                <span id="modalOriginalPrice" class="text-muted text-decoration-line-through fs-6"></span>
                                <span id="modalCurrentPrice" class="text-danger fw-bold fs-4"></span>
                                <span id="modalDiscountBadge" class="badge bg-danger px-2 py-1"></span>
                            </div>
                        </div>

                        <!-- Stock Status - Below Price -->
                        <div class="mt-2 text-center">
                            <span class="text-muted me-2 small">Tình trạng:</span>
                            <span id="modalStockStatus" class="badge"></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 bg-light justify-content-between py-2">
                <button type="button" class="btn btn-outline-danger btn-sm" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>Đóng
                </button>
                <button type="button" id="modalAddToCartBtn" class="btn btn-success px-4 py-2 fw-bold shadow-sm" onclick="addToCartFromModal()">
                    <i class="fas fa-cart-plus me-2"></i>Thêm vào giỏ hàng
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/product-api.js" asp-append-version="true"></script>
    <script src="~/js/products.js" asp-append-version="true"></script>
    <script src="~/js/product-enhancements.js" asp-append-version="true"></script>
}


