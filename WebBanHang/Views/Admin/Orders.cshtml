@model List<WebBanHang.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    var status = ViewData["Status"]?.ToString();
    var currentPage = (int)(ViewData["CurrentPage"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
    var totalOrders = (int)(ViewData["TotalOrders"] ?? 0);
}

<div class="container-xxl py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0"><i class="fas fa-shopping-cart me-2"></i>Quản lý đơn hàng</h2>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show auto-close">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show auto-close">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filter -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-action="Orders" class="row g-3">
                <div class="col-md-4">
                    <select name="status" class="form-select">
                        <option value="">Tất cả trạng thái</option>
                        <option value="Pending" selected="@(status == "Pending" ? "selected" : null)">Chờ xử lý</option>
                        <option value="Processing" selected="@(status == "Processing" ? "selected" : null)">Đang xử lý</option>
                        <option value="Shipped" selected="@(status == "Shipped" ? "selected" : null)">Đã gửi hàng</option>
                        <option value="Delivered" selected="@(status == "Delivered" ? "selected" : null)">Đã giao hàng</option>
                        <option value="Completed" selected="@(status == "Completed" ? "selected" : null)">Hoàn thành</option>
                        <option value="Cancelled" selected="@(status == "Cancelled" ? "selected" : null)">Đã hủy</option>
                    </select>
                </div>
                <div class="col-md-8">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="fas fa-filter me-1"></i>Lọc
                    </button>
                    <a asp-action="Orders" class="btn btn-secondary">
                        <i class="fas fa-redo me-1"></i>Đặt lại
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Orders Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 80px;">ID</th>
                            <th>Khách hàng</th>
                            <th>Liên hệ</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            var statusClass = order.Status switch
                            {
                                "Completed" => "success",
                                "Delivered" => "success",
                                "Shipped" => "info",
                                "Processing" => "warning",
                                "Pending" => "secondary",
                                "Cancelled" => "danger",
                                _ => "secondary"
                            };

                            <tr>
                                <td><strong>#@order.Id</strong></td>
                                <td>
                                    <div>
                                        <strong>@order.CustomerName</strong>
                                        @if (order.User != null)
                                        {
                                            <br /><small class="text-muted">@order.User.Email</small>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <div class="small">
                                        <div><i class="fas fa-phone me-1 text-primary"></i>@order.CustomerPhone</div>
                                        <div class="text-muted">
                                            <i class="fas fa-map-marker-alt me-1"></i>
                                            @if (!string.IsNullOrEmpty(order.ShippingAddress))
                                            {
                                                @(order.ShippingAddress.Length > 30 ? order.ShippingAddress.Substring(0, 30) + "..." : order.ShippingAddress)
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td><strong class="text-danger">@order.TotalAmount.ToString("N0") ₫</strong></td>
                                <td>
                                    <span class="badge bg-@statusClass">@order.Status</span>
                                </td>
                                <td class="text-end">
                                    <a asp-action="OrderDetail" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye"></i> Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.Count == 0)
            {
                <div class="text-center text-muted py-5">
                    <i class="fas fa-shopping-cart fa-3x mb-3"></i>
                    <p>Không tìm thấy đơn hàng nào.</p>
                </div>
            }
            else
            {
                <!-- Pagination -->
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted small">
                        Hiển thị @Model.Count / @totalOrders đơn hàng
                    </div>
                    @if (totalPages > 1)
                    {
                        <nav>
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" asp-action="Orders" asp-route-status="@status" asp-route-page="@(currentPage - 1)">Trước</a>
                                </li>
                                @for (int i = 1; i <= totalPages; i++)
                                {
                                    <li class="page-item @(i == currentPage ? "active" : "")">
                                        <a class="page-link" asp-action="Orders" asp-route-status="@status" asp-route-page="@i">@i</a>
                                    </li>
                                }
                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <a class="page-link" asp-action="Orders" asp-route-status="@status" asp-route-page="@(currentPage + 1)">Sau</a>
                                </li>
                            </ul>
                        </nav>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto close alerts after 4 seconds
        setTimeout(function() {
            var alerts = document.querySelectorAll('.alert.auto-close');
            alerts.forEach(function(alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 4000);
    </script>
}
