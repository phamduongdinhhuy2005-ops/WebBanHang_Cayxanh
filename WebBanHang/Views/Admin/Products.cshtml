@model List<WebBanHang.Models.Product>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
    var search = ViewData["Search"]?.ToString();
    var category = ViewData["Category"]?.ToString();
    var currentPage = (int)(ViewData["CurrentPage"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
    var totalProducts = (int)(ViewData["TotalProducts"] ?? 0);
}

<div class="container-xxl py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0"><i class="fas fa-box me-2"></i>Quản lý sản phẩm</h2>
        <a asp-action="CreateProduct" class="btn btn-success">
            <i class="fas fa-plus-circle me-2"></i>Thêm sản phẩm mới
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show auto-close">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show auto-close">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Search & Filter -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-action="Products" class="row g-3">
                <div class="col-md-5">
                    <input type="text" name="search" class="form-control" placeholder="Tìm kiếm theo tên hoặc mô tả..." value="@search" />
                </div>
                <div class="col-md-3">
                    <select name="category" class="form-select">
                        <option value="">Tất cả danh mục</option>
                        <option value="laptop" selected="@(category == "laptop" ? "selected" : null)">Laptop</option>
                        <option value="phukien" selected="@(category == "phukien" ? "selected" : null)">Phụ kiện</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="fas fa-search me-1"></i>Tìm kiếm
                    </button>
                    <a asp-action="Products" class="btn btn-secondary">
                        <i class="fas fa-redo me-1"></i>Đặt lại
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Products Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 80px; white-space: nowrap;">Hình ảnh</th>
                            <th style="width: 50px; white-space: nowrap;">ID</th>
                            <th style="min-width: 250px;">Tên sản phẩm</th>
                            <th style="width: 150px; white-space: nowrap;">Giá</th>
                            <th style="width: 120px; white-space: nowrap;">Danh mục</th>
                            <th style="width: 100px; white-space: nowrap; text-align: center;">Tồn kho</th>
                            <th style="width: 180px; white-space: nowrap; text-align: right;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model)
                        {
                            <tr>
                                <td>
                                    <img src="@product.ImageUrl" alt="@product.Name" class="img-thumbnail" style="width: 60px; height: 60px; object-fit: cover;" />
                                </td>
                                <td>@product.Id</td>
                                <td>
                                    <strong>@product.Name</strong>
                                    <br />
                                    <small class="text-muted">@product.Description</small>
                                </td>
                                <td>
                                    @if (product.Discount > 0)
                                    {
                                        <span class="text-decoration-line-through text-muted small">@product.OriginalPrice</span>
                                        <br />
                                        <strong class="text-danger">@product.Price</strong>
                                        <span class="badge bg-danger ms-1">-@product.Discount%</span>
                                    }
                                    else
                                    {
                                        <strong>@product.Price</strong>
                                    }
                                </td>
                                <td>
                                    @if (product.Category?.Contains("laptop") == true)
                                    {
                                        <span class="badge bg-primary">Laptop</span>
                                    }
                                    @if (product.Category?.Contains("phukien") == true)
                                    {
                                        <span class="badge bg-info">Phụ kiện</span>
                                    }
                                    @if (product.Category?.Contains("khuyenmai") == true)
                                    {
                                        <span class="badge bg-danger">Khuyến mãi</span>
                                    }
                                </td>
                                <td style="text-align: center;">
                                    @if (product.StockQuantity == 0)
                                    {
                                        <span class="badge bg-secondary">Hết hàng</span>
                                    }
                                    else if (product.StockQuantity < 10)
                                    {
                                        <span class="badge bg-warning text-dark">@product.StockQuantity</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">@product.StockQuantity</span>
                                    }
                                </td>
                                <td class="text-end" style="white-space: nowrap;">
                                    <a asp-action="EditProduct" asp-route-id="@product.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-edit"></i> Sửa
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteProductModal@(product.Id)">
                                        <i class="fas fa-trash"></i> Xóa
                                    </button>

                                    <!-- Delete Confirmation Modal -->
                                    <div class="modal fade" id="deleteProductModal@(product.Id)" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Xác nhận xóa</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    Bạn có chắc muốn xóa sản phẩm <strong>@product.Name</strong>?
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                                    <form method="post" asp-action="DeleteProduct" asp-route-id="@product.Id" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-danger">Xóa</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.Count == 0)
            {
                <div class="text-center text-muted py-5">
                    <i class="fas fa-box fa-3x mb-3"></i>
                    <p>Không tìm thấy sản phẩm nào.</p>
                </div>
            }
            else
            {
                <!-- Pagination -->
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted small">
                        Hiển thị @Model.Count / @totalProducts sản phẩm
                    </div>
                    @if (totalPages > 1)
                    {
                        <nav>
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" asp-action="Products" asp-route-search="@search" asp-route-category="@category" asp-route-page="@(currentPage - 1)">Trước</a>
                                </li>
                                @for (int i = 1; i <= totalPages; i++)
                                {
                                    <li class="page-item @(i == currentPage ? "active" : "")">
                                        <a class="page-link" asp-action="Products" asp-route-search="@search" asp-route-category="@category" asp-route-page="@i">@i</a>
                                    </li>
                                }
                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <a class="page-link" asp-action="Products" asp-route-search="@search" asp-route-category="@category" asp-route-page="@(currentPage + 1)">Sau</a>
                                </li>
                            </ul>
                        </nav>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto close alerts after 4 seconds
        setTimeout(function() {
            var alerts = document.querySelectorAll('.alert.auto-close');
            alerts.forEach(function(alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 4000);
    </script>
}
