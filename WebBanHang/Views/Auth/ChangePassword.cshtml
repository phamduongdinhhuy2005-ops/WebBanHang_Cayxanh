@model WebBanHang.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    var userEmail = Context.Session.GetString("_UserEmail") ?? "";
    var userDisplayName = Context.Session.GetString("_UserDisplayName") ?? "";
}

<div class="container py-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-center mb-3">
                        <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="fas fa-user fa-2x"></i>
                        </div>
                        <h5 class="mt-3 mb-1 fw-bold">@userDisplayName</h5>
                        <p class="text-muted small mb-0">@userEmail</p>
                    </div>
                    <hr />
                    <nav class="nav flex-column">
                        <a class="nav-link" asp-controller="Auth" asp-action="Profile">
                            <i class="fas fa-user me-2"></i>Thông tin cá nhân
                        </a>
                        <a class="nav-link active" asp-controller="Auth" asp-action="ChangePassword">
                            <i class="fas fa-key me-2"></i>Đổi mật khẩu
                        </a>
                        @{
                            var userRole = Context.Session.GetString("_UserRole");
                            var isAdmin = userRole == "Admin";
                        }
                        @if (!isAdmin)
                        {
                            <a class="nav-link" asp-controller="Auth" asp-action="OrderHistory">
                                <i class="fas fa-history me-2"></i>Lịch sử mua hàng
                            </a>
                        }
                        <hr class="my-2" />
                        <form method="post" asp-controller="Auth" asp-action="Logout" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="nav-link text-danger border-0 bg-transparent w-100 text-start">
                                <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                            </button>
                        </form>
                    </nav>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="fas fa-key me-2"></i>Đổi mật khẩu
                    </h5>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-info" role="alert">
                        <i class="fas fa-info-circle me-2"></i>
                        Để bảo mật tài khoản, vui lòng sử dụng mật khẩu mạnh có ít nhất 6 ký tự.
                    </div>

                    <form method="post" asp-controller="Auth" asp-action="ChangePassword">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-4">
                            <label asp-for="CurrentPassword" class="form-label fw-semibold">
                                <i class="fas fa-lock me-1"></i>Mật khẩu hiện tại
                            </label>
                            <input asp-for="CurrentPassword" class="form-control" placeholder="Nhập mật khẩu hiện tại" autofocus />
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>

                        <hr class="my-4" />

                        <div class="mb-4">
                            <label asp-for="NewPassword" class="form-label fw-semibold">
                                <i class="fas fa-lock me-1"></i>Mật khẩu mới
                            </label>
                            <input asp-for="NewPassword" class="form-control" placeholder="Nhập mật khẩu mới (tối thiểu 6 ký tự)" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmNewPassword" class="form-label fw-semibold">
                                <i class="fas fa-lock me-1"></i>Xác nhận mật khẩu mới
                            </label>
                            <input asp-for="ConfirmNewPassword" class="form-control" placeholder="Nhập lại mật khẩu mới" />
                            <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-check me-2"></i>Đổi mật khẩu
                            </button>
                            <a asp-controller="Auth" asp-action="Profile" class="btn btn-outline-secondary">
                                <i class="fas fa-times me-2"></i>Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
