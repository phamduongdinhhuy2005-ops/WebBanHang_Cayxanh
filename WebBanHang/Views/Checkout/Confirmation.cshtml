@model WebBanHang.Models.Order
@{
    ViewData["Title"] = "Xác nhận đơn hàng";
}

<section class="py-5">
    <div class="container-xxl">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-10">
                <!-- Header -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <div class="text-center mb-4">
                            <div class="mb-3">
                                <i class="fas fa-clipboard-check fa-3x text-warning"></i>
                            </div>
                            <h2 class="fw-bold mb-2">Xác nhận đơn hàng</h2>
                            <p class="text-muted">Vui lòng kiểm tra thông tin đơn hàng trước khi xác nhận</p>
                        </div>

                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show">
                                <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <!-- Order Info -->
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <i class="fas fa-receipt text-primary"></i>
                                    <strong>Mã đơn hàng:</strong>
                                </div>
                                <div class="ms-4">#@Model.Id</div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <i class="fas fa-calendar text-primary"></i>
                                    <strong>Ngày đặt:</strong>
                                </div>
                                <div class="ms-4">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                        </div>

                        <!-- Customer Info -->
                        <div class="card bg-light border-0 mb-4">
                            <div class="card-body">
                                <h5 class="card-title mb-3">
                                    <i class="fas fa-user me-2 text-primary"></i>
                                    Thông tin người nhận
                                </h5>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="mb-2"><strong>Họ tên:</strong></div>
                                        <div>@Model.CustomerName</div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-2"><strong>Email:</strong></div>
                                        <div>@Model.CustomerEmail</div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-2"><strong>Số điện thoại:</strong></div>
                                        <div>@Model.CustomerPhone</div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-2"><strong>Địa chỉ giao hàng:</strong></div>
                                        <div>@Model.ShippingAddress</div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(Model.Notes))
                                    {
                                        <div class="col-12">
                                            <div class="mb-2"><strong>Phương thức thanh toán:</strong></div>
                                            <div>@Model.Notes</div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Order Items -->
                        <div class="card bg-light border-0 mb-4">
                            <div class="card-body">
                                <h5 class="card-title mb-3">
                                    <i class="fas fa-box me-2 text-primary"></i>
                                    Sản phẩm đã đặt
                                </h5>
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Sản phẩm</th>
                                                <th class="text-center">Số lượng</th>
                                                <th class="text-end">Đơn giá</th>
                                                <th class="text-end">Thành tiền</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.OrderItems)
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center gap-3">
                                                            @if (item.Product != null && !string.IsNullOrEmpty(item.Product.ImageUrl))
                                                            {
                                                                <img src="@item.Product.ImageUrl" alt="@item.ProductName" 
                                                                     style="width:50px;height:50px;object-fit:cover;border-radius:0.25rem;" 
                                                                     class="shadow-sm">
                                                            }
                                                            <div>
                                                                <div class="fw-semibold">@item.ProductName</div>
                                                                @if (item.Product != null && item.Product.StockQuantity < item.Quantity)
                                                                {
                                                                    <small class="text-danger">
                                                                        <i class="fas fa-exclamation-triangle"></i>
                                                                        Chỉ còn @item.Product.StockQuantity trong kho
                                                                    </small>
                                                                }
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td class="text-center">@item.Quantity</td>
                                                    <td class="text-end">@item.ProductPrice.ToString("N0")₫</td>
                                                    <td class="text-end fw-semibold">@item.Subtotal.ToString("N0")₫</td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot class="table-light">
                                            <tr>
                                                <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                                                <td class="text-end fw-bold text-danger fs-5">@Model.TotalAmount.ToString("N0")₫</td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex flex-column flex-md-row gap-3 justify-content-center">
                            <form method="post" asp-action="CancelOrder" asp-route-id="@Model.Id" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-secondary btn-lg" 
                                        onclick="return confirm('Bạn có chắc muốn hủy đơn hàng này?')">
                                    <i class="fas fa-times me-2"></i>Hủy đơn hàng
                                </button>
                            </form>

                            <a href="/Checkout" class="btn btn-outline-primary btn-lg">
                                <i class="fas fa-edit me-2"></i>Chỉnh sửa
                            </a>

                            <form method="post" asp-action="ConfirmOrder" asp-route-id="@Model.Id" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success btn-lg">
                                    <i class="fas fa-check-circle me-2"></i>Xác nhận đặt hàng
                                </button>
                            </form>
                        </div>

                        <div class="text-center mt-4">
                            <small class="text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                Sau khi xác nhận, đơn hàng sẽ được xử lý và bạn không thể chỉnh sửa
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Auto-dismiss alerts
        document.querySelectorAll('.alert').forEach(alert => {
            setTimeout(() => {
                const bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            }, 5000);
        });
    </script>
}
