@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<section class="py-5">
    <div class="container-xxl">
        @await Html.PartialAsync("_Breadcrumb")
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 text-center">
                <h2 class="fw-bold">Cảm ơn! Đơn hàng của bạn đã được gửi</h2>
                <p class="text-muted">Chúng tôi đã nhận đơn hàng và sẽ liên hệ để xác nhận thông tin.</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">Quay về trang chủ</a>
            </div>
        </div>
    </div>
</section>
